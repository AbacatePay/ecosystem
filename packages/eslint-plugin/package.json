{
  "name": "@abacatepay/eslint-plugin",
  "version": "0.1.2",
  "type": "module",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": {
    "name": "AbacatePay",
    "email": "opensource@abacatepay.com",
    "url": "https://abacatepay.com"
  },
  "maintainers": [
    {
      "name": "Almeida",
      "url": "https://github.com/almeidazs"
    }
  ],
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "scripts": {
    "test": "bun test",
    "build": "bun run scripts/version.ts && tsup",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "eslint": "^9.39.2"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "tsup": "^8.5.0",
    "typescript": "^5"
  },
  "description": "Do not hardcode your AbacatePay secrets with this plugin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbacatePay/ecosystem.git"
  },
  "bugs": {
    "url": "https://github.com/AbacatePay/abacatepay-eslint/issues"
  },
  "homepage": "https://github.com/AbacatePay/abacatepay-eslint#readme",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "security",
    "secrets",
    "abacatepay",
    "lint"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "eslintConfig": {
    "env": {
      "node": true
    }
  }
}
